#!/usr/bin/env python3

import sys
import json

try:
    import requests
except ImportError:
    print("No requests module found. Install it with: pip install requests")
    sys.exit(1)

# Read configuration and alert
alert_file = open(sys.argv[1])
alert_json = json.load(alert_file)
hook_url = sys.argv[3]

# Generate message structure
msg = {
    "text": f"Wazuh Alert: {alert_json.get('rule').get('description')}\nLevel: {alert_json.get('rule').get('level')}\nAgent: {alert_json.get('agent').get('name')}"
}

# Send to Slack
requests.post(hook_url, data=json.dumps(msg), headers={'content-type': 'application/json'})
