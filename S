#!/usr/bin/env python3
import sys
import json
import requests

# Wazuh pass arguments: [1] alert file, [3] hook url
alert_file = sys.argv[1]
hook_url = sys.argv[3]

with open(alert_file) as f:
    alert_json = json.load(f)

msg = {
    "text": f"🚨 *Wazuh Alert*\n*Rule:* {alert_json['rule']['description']}\n*Level:* {alert_json['rule']['level']}\n*Agent:* {alert_json['agent']['name']}"
}

requests.post(hook_url, json=msg)
