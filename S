#!/usr/bin/env python3
import sys
import json
import requests

# Configuration
alert_file = sys.argv[1]
ollama_url = "http://192.168.10.2:11434/api/generate"
# Thabbet fi URL mta3 Slack (na7i el 'P' el zayda ken mawjouda fi t-tul)
slack_url = "https://3hooks.slack.com/services/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"

# 1. Read Wazuh Alert (Line by Line)
alert_json = {}
try:
    with open(alert_file, 'r') as f:
        # Ne5dou e5er line fil file (the latest alert)
        for line in f:
            line = line.strip()
            if line:
                alert_json = json.loads(line)
except Exception as e:
    print(f"Error reading alert: {e}")
    sys.exit(1)

if not alert_json:
    print("No alert found in file.")
    sys.exit(1)

description = alert_json.get('rule', {}).get('description', 'No description')
level = alert_json.get('rule', {}).get('level', 0)
agent = alert_json.get('agent', {}).get('name', 'Unknown')

# 2. Get AI Analysis from Ollama
prompt = f"Analyze this security alert and provide a 1-sentence summary: {description}. Level: {level}. Agent: {agent}."
payload = {"model": "llama3", "prompt": prompt, "stream": False}

try:
    ollama_res = requests.post(ollama_url, json=payload, timeout=45)
    ai_analysis = ollama_res.json().get('response', 'AI analysis unavailable.')
except Exception as e:
    ai_analysis = f"Ollama Error: {str(e)}"

# 3. Send Consolidated Alert to Slack
slack_data = {
    "text": f"🚨 *Wazuh + AI Alert*\n"
            f"*Rule:* {description} (Level {level})\n"
            f"*Agent:* {agent}\n"
            f"*AI Assessment:* {ai_analysis}"
}

try:
    requests.post(slack_url, json=slack_data, timeout=10)
except Exception as e:
    print(f"Error sending to Slack: {e}")
